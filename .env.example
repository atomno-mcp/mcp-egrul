# mcp-egrul — переменные окружения (пример, без реальных значений)

# === SQLite data store ===
# Путь к файлу SQLite со слепком ЕГРЮЛ/ЕГРИП.
# По умолчанию — ./mcp_egrul_data.sqlite в CWD процесса.
MCP_EGRUL_DB=./mcp_egrul_data.sqlite

# === HTTP client ===
# User-Agent для запросов к egrul.nalog.ru и файловому хранилищу open-data ФНС.
# По политике ФНС — желательно указывать контактный email в User-Agent.
MCP_EGRUL_USER_AGENT=mcp-egrul/0.1 (+https://github.com/atomno-labs/mcp-egrul)

# Таймаут одного HTTP-запроса в секундах.
MCP_EGRUL_HTTP_TIMEOUT=30

# === Ingestion ===
# Каталог, куда `atomno-mcp-egrul-import` складывает скачанные дампы ФНС.
MCP_EGRUL_DUMPS_DIR=./dumps

# === Логирование ===
# DEBUG / INFO / WARNING / ERROR
MCP_EGRUL_LOG_LEVEL=INFO

# === Hosted-режим (Pro) ===
# Если задан ATOMNO_API_KEY — все семь тулзов проксируются в hosted Pro API
# (`api.atomno-mcp.ru`) вместо обращения к локальному SQLite. См. SPEC §5.4, §5.4.1.
# Получить ключ: https://atomno.ru/pro (план, пока Free-tier без регистрации).
# Никакого silent fallback: если hosted API недоступен — клиент бросит
# SourceUnavailableError / HostedAuthError / RateLimitedError (НЕ переключится
# на локальный SQLite молча).
# ATOMNO_API_KEY=
# ATOMNO_API_BASE=https://api.atomno-mcp.ru/mcp-egrul/v1
